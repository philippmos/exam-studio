# Database Configuration
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Api Configuration
CORS_ORIGINS=

# Auth0 / OAuth2 — shared by the API (OAuth2 resource server) and the SPA
# client. See docs/auth0-setup.md.
# AUTH0_DOMAIN:    your tenant domain, e.g. your-tenant.eu.auth0.com (no scheme/slash)
# AUTH0_AUDIENCE:  the API identifier from Auth0, e.g. https://api.exam-studio
# AUTH0_CLIENT_ID: the SPA application's Client ID (client only)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=

GRAPHQL_URL=/graphql