# Database Configuration
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Api Configuration
CORS_ORIGINS=

# Auth0 / OAuth2 (the API is an OAuth2 resource server). See docs/auth0-setup.md.
