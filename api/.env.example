# Copy this file to `.env` and adjust for local development.

# --- Core -------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://exam:exam@localhost:5432/examstudio
# Comma separated list of allowed CORS origins (Angular dev server by default).
CORS_ORIGINS=http://localhost:4200
# Serve the in-browser GraphQL IDE and keep schema introspection on (dev only).
DEBUG=false

# --- Auth0 (OAuth2 resource server) -----------------------------------------
# The API rejects every /graphql request with HTTP 401 until these are set.
# See docs/auth0-setup.md.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# --- Observability (all optional; sensible defaults) ------------------------
LOG_LEVEL=INFO
# JSON logs for production; set to false for a coloured console renderer in dev.
LOG_JSON=true
# Deployment tag reported in logs, traces and Sentry.
ENVIRONMENT=development
# Expose Prometheus metrics at /metrics.
METRICS_ENABLED=true
# OTLP/HTTP endpoint for traces, e.g. http://otel-collector:4318. Empty = off.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Sentry DSN for error reporting. Empty = off.
SENTRY_DSN=
